---
const { title = "SB" } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
</head>

<body>

<header class="header">
  <div class="brand">SB</div>

  <button class="hamburger" id="menuBtn">☰</button>
</header>

<!-- FULLSCREEN MENU OVERLAY -->
<div class="menu" id="menu">
  <nav>
    <a href="/">Home</a>
    <a href="/bio">Bio</a>
    <a href="/artwork">Artwork</a>
    <a href="/writings">Writings</a>
    <a href="/classes">Classes</a>
    <a href="/contact">Contact</a>
  </nav>
</div>

<main>
  <slot />
</main>

<footer>© 2026 SB</footer>

<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("menu");

  btn?.addEventListener("click", () => {
    menu.classList.toggle("open");
  });

  menu?.addEventListener("click", (e) => {
    if (e.target === menu) menu.classList.remove("open");
  });
</script>

</body>
</html>

<style>
/* BASE */
body {
  margin: 0;
  background: #050505;
  color: #eaeaea;
  font-family: system-ui, sans-serif;
}

/* HEADER (minimal) */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;

  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 14px 18px;
  z-index: 1000;

  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(10px);
}

.brand {
  font-size: 11px;
  letter-spacing: .25em;
  opacity: .8;
}

/* HAMBURGER */
.hamburger {
  font-size: 22px;
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  opacity: .85;
}

/* FULLSCREEN MENU */
.menu {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.92);

  display: flex;
  align-items: center;
  justify-content: center;

  opacity: 0;
  pointer-events: none;
  transition: opacity 300ms ease;
}

.menu.open {
  opacity: 1;
  pointer-events: auto;
}

.menu nav {
  display: flex;
  flex-direction: column;
  gap: 18px;
  text-align: center;
}

.menu a {
  color: #ddd;
  text-decoration: none;
  font-size: 14px;
  letter-spacing: .12em;
  opacity: .8;
  transition: opacity 200ms ease;
}

.menu a:hover {
  opacity: 1;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 40px;
  font-size: 11px;
  color: #666;
}

/* IMAGE FADE-IN GLOBAL RULE */
img {
  opacity: 0;
  animation: fadeIn 900ms ease forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(1.03);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
</style>
