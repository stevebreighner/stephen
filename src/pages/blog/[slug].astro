---
import Layout from "../../layouts/Layout.astro";
import { readFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

export function getStaticPaths() {
  const __dirname = dirname(fileURLToPath(import.meta.url));
  const allPosts = Object.entries(
    import.meta.glob("../../content/blog/*.md", { eager: true })
  );

  return allPosts.map(([path, post]) => {
    const source = readFileSync(join(__dirname, path), "utf-8");

    return {
      params: {
        slug: path.split("/").pop().replace(".md", ""),
      },
      props: {
        post,
        hasTiktok: source.includes("tiktok-embed"),
      },
    };
  });
}

const { post, hasTiktok } = Astro.props;
---

<Layout title={post.frontmatter.title}>
  <div class="wrap">
    <a class="back" href="/blog">← Back</a>

    <h1>{post.frontmatter.title}</h1>

    <div class="content">
      <post.Content />
    </div>
  </div>

  {hasTiktok && (
    <script is:inline async src="https://www.tiktok.com/embed.js"></script>
  )}
</Layout>