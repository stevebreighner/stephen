---

import Layout from "../layouts/Layout.astro";

const posts = Object.entries(
import.meta.glob("../content/blog/*.md", { eager: true })
).map(([path, mod]) => ({
path,
...mod,
}));

posts.sort(
(a, b) =>
new Date(b.frontmatter.date).getTime() -
new Date(a.frontmatter.date).getTime()
);
---

<Layout title="Blog">
  <div class="container">
    <div class="top">
      <h1>Blog</h1>
 
  <div class="controls">
    <input
      id="search"
      type="text"
      placeholder="Search posts..."
    />

    <button id="listView" class="view-btn">
      ☰
    </button>

    <button id="largeView" class="view-btn">
      ⊞
    </button>
  </div>
</div>

<p class="count" id="count">{posts.length} posts</p>

<div id="posts">
  {
    posts.map((post) => {
      const slug = post.path
        .split("/")
        .pop()
        .replace(".md", "");

      return (
        <a
          class="card"
          href={`/blog/${slug}`}
          data-title={post.frontmatter.title.toLowerCase()}
        >
          <div class="meta">
            {post.frontmatter.date}
          </div>

          <h2>
            {post.frontmatter.video && "🎬 "}
            {post.frontmatter.title}
          </h2>

          <p>
            {post.frontmatter.description ||
              "Click to read article..."}
          </p>
        </a>
      );
    })
  }
</div>
 

  </div>

  <script>
    const input = document.getElementById("search");
    const count = document.getElementById("count");
    const cards = document.querySelectorAll(".card");

    function update() {
      const q = input.value.toLowerCase();

      let visible = 0;

      cards.forEach((card) => {
        const title = card.dataset.title || "";

        const show = title.includes(q);

        card.style.display = show ? "block" : "none";

        if (show) visible++;
      });

      count.textContent =
        `${visible} of ${cards.length} posts`;
    }

    input?.addEventListener("input", update);

    update();

    const listBtn =
      document.getElementById("listView");

    const largeBtn =
      document.getElementById("largeView");

    listBtn?.addEventListener("click", () => {
      document.body.classList.remove(
        "large-view"
      );
    });

    largeBtn?.addEventListener("click", () => {
      document.body.classList.add(
        "large-view"
      );
    });
  </script>

</Layout>

<style>
.container {
  max-width: 950px;
  margin: 90px auto;
  padding: 20px;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
}

.controls {
  display: flex;
  align-items: center;
  gap: 8px;
}

h1 {
  margin: 0;
  font-size: 13px;
  font-weight: 400;
  letter-spacing: .25em;
  color: #888;
  text-transform: uppercase;
}

.count {
  color: #666;
  font-size: 12px;
  margin: 12px 0 30px;
}

#search {
  background: #111;
  border: 1px solid #222;
  color: #ddd;
  padding: 10px 12px;
  width: 240px;
  outline: none;
}

#search:focus {
  border-color: #444;
}

.view-btn {
  background: #111;
  color: #ccc;
  border: 1px solid #222;
  cursor: pointer;
  padding: 10px 12px;
}

.view-btn:hover {
  border-color: #444;
}

.card {
  display: block;
  padding: 28px 0;
  border-bottom: 1px solid #1b1b1b;
  text-decoration: none;
  color: inherit;
  transition: .15s;
}

.card:hover {
  padding-left: 10px;
}

.meta {
  font-size: 11px;
  color: #666;
  margin-bottom: 8px;
  letter-spacing: .08em;
}

.card h2 {
  margin: 0;
  color: #eee;
  font-size: 24px;
  font-weight: 500;
  line-height: 1.3;
}

.card p {
  margin-top: 10px;
  color: #888;
  font-size: 14px;
  line-height: 1.6;
  max-width: 700px;
}

.large-view .card {
  padding: 42px 0;
}

.large-view .card h2 {
  font-size: 34px;
}

.large-view .card p {
  font-size: 16px;
}

@media (max-width: 700px) {
  .top {
    flex-direction: column;
    align-items: stretch;
  }

  .controls {
    flex-wrap: wrap;
  }

  #search {
    width: 100%;
  }
}
</style>
