---
const { title = "Stephen Breighner" } = Astro.props;

import "../styles/global.css";
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
</head>

<body>

<!-- HEADER -->
<header class="header">
  <div class="brand">SB</div>

  <button class="hamburger" id="menuBtn">☰</button>
</header>

<!-- FULLSCREEN MENU -->
<div class="menu" id="menu">
  <nav>
   
    <a href="/artwork">Artwork</a>
    <a href="/blog">Blog</a>
    <a href="/writings">Writings</a>
      
  </nav>
</div>

<!-- PAGE CONTENT -->
<main>
  <slot />
</main>

<!-- FOOTER -->
<footer class="footer">
  <span>© 2026 <a id = "sb" href="/contact">SB</a></span>
  <a href="/tos">Terms of Service</a>
</footer>
<!-- MENU SCRIPT -->
<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("menu");

  btn?.addEventListener("click", () => {
    menu.classList.toggle("open");
  });

  menu?.addEventListener("click", (e) => {
    if (e.target === menu) {
      menu.classList.remove("open");
    }
  });
</script>
<style>.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  margin-top: 5rem;
  padding: 2rem 0;
  font-size: 0.85rem;
  opacity: 0.65;
}

.footer a {
  color: inherit;
  text-decoration: none;
}
a#sb{text-decoration:underline;}

.footer a:hover {
  opacity: 1;
}

@media (max-width: 700px) {
  .footer {
    flex-direction: column;
    gap: 0.5rem;
    text-align: center;
  }
}</style>
</body>
</html>

